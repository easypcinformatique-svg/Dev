# Ticketmaster Discovery API key (free at developer.ticketmaster.com)
TM_API_KEY=your_ticketmaster_api_key

# Twilio SMS (optional — leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_PHONE_NUMBER=+33xxxxxxxxxx

# Telegram Bot (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
