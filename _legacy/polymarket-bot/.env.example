# Configuration de l'application
SECRET_KEY=change-me-to-a-random-string
UPLOAD_FOLDER=./uploads

# Google OAuth2 - Créer un projet sur https://console.cloud.google.com
# Activer les APIs : Gmail API, Google Drive API
# Créer des identifiants OAuth2 (type: Application Web)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback

# Dossier Google Drive contenant les scans
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Labels Gmail à surveiller (séparés par des virgules)
GMAIL_LABELS=INBOX
GMAIL_SEARCH_QUERY=has:attachment filename:pdf OR filename:jpg OR filename:png subject:(facture OR invoice OR reçu)
